{
    "version": 2,
    "builds": [
        {
            "src": "react/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/server.js"
        },
        {
            "src": "/data.json",
            "dest": "/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/react/dist/$1"
        }
    ]
}